terraform {
  required_version = ">= 1.9.0"

  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = "~> 4.0"
    }
    azuread = {
      source  = "hashicorp/azuread"
      version = "~> 3.0"
    }
    cloudflare = {
      source  = "cloudflare/cloudflare"
      version = "~> 4.42"
    }
  }

  # backend "remote" {
  #   hostname     = "app.terraform.io"
  #   organization = "paragon-cloud"
  #
  #   workspaces {
  #     name = "paragon-azure-infra"
  #   }
  # }
}
